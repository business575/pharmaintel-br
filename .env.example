# PharmaIntel BR — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o arquivo .env no Git

# ── Groq API (Starter — grátis, rápido) ───────────────────────────────────
# Obtenha em: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── DeepSeek API (Pro — grátis, preciso) ──────────────────────────────────
# Obtenha em: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# ── UN Comtrade API ────────────────────────────────────────────────────────
# Cadastro gratuito em: https://comtradeplus.un.org
COMTRADE_API_KEY=your_comtrade_key_here

# ── FastAPI Backend ────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here
API_PORT=8000

# ── Streamlit ──────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Login do Dashboard ─────────────────────────────────────────────────────
# Credenciais para acessar o dashboard Streamlit
APP_USERNAME=admin
# Gere um hash com: python -c "import hashlib; print(hashlib.sha256(b'suasenha').hexdigest())"
APP_PASSWORD_HASH=your_sha256_hash_here
# Em desenvolvimento você pode usar senha em texto plano (menos seguro):
APP_PASSWORD=pharmaintel2024

# ── Stripe (Pagamentos) ────────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
# Webhook secret — gerado ao criar o endpoint no Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Banco de dados ─────────────────────────────────────────────────────────
# Padrão: SQLite local em data/pharmaintel.db
# Para produção use PostgreSQL: postgresql://user:pass@host/db
DATABASE_URL=

# ── Ambiente ───────────────────────────────────────────────────────────────
APP_ENV=development
